{
  "version": 2,
  "name": "hex-conquer",
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
        "src": "style.css",
        "use": "@vercel/static"
    },
    {
        "src": "game.js",
        "use": "@vercel/static"
    },
    {
        "src": "sw.js",
        "use": "@vercel/static"
    },
    {
        "src": "manifest.json",
        "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/sw.js",
      "headers": { "cache-control": "no-cache" },
      "dest": "/sw.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
